    </div>
    <div class="stat-card">
      <div class="stat-label">Sin premio</div>
      <div class="stat-value" style="color:rgba(255,255,255,0.3)" id="stat-losses">0</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">% ganadores</div>
      <div class="stat-value red" id="stat-pct">0%</div>
    </div>
  </div>

  <!-- Config monto mínimo -->
  <div class="section-title">Configuración</div>
  <div class="admin-form">
    <div>
      <label class="form-label">Monto mínimo de compra ($)</label>
      <input class="admin-input" type="number" id="admin-min" value="50000">
    </div>
    <button class="btn-admin" onclick="saveConfig()">Guardar</button>
  </div>

  <!-- Prizes table -->
  <div class="section-title">Premios de la ruleta</div>
  <p style="font-size:12px;color:rgba(255,255,255,0.3);margin-bottom:16px;">
    Los porcentajes deben sumar 100%. Editá los premios según tu estrategia.
  </p>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Premio</th>
          <th>Tipo</th>
          <th>Probabilidad</th>
          <th>Color</th>
          <th>Activo</th>
        </tr>
      </thead>
      <tbody id="prizes-tbody"></tbody>
    </table>
  </div>
  <div style="margin-top:12px;font-size:11px;color:rgba(255,255,255,0.2);">
    * Para editar premios, modificá el array <code>PRIZES</code> en el código fuente.
  </div>

  <!-- Spin log -->
  <div class="section-title">Historial de giros</div>
  <div id="spin-log"></div>

  <!-- Clear data -->
  <div style="margin-top:32px;padding-top:24px;border-top:1px solid var(--border);">
    <button class="btn-secondary" onclick="clearLog()">🗑 Limpiar historial</button>
  </div>
</div>

<!-- Admin toggle (hidden) -->
<button id="admin-toggle" onclick="promptAdmin()">⚙ admin</button>

<script>
/* ══════════════════════════════════════════════════════
   CONFIGURACIÓN — editá esto para personalizar
══════════════════════════════════════════════════════ */

const CONFIG = {
  minAmount: 50000,       // monto mínimo para girar
  adminPass: 'rsadmin2024', // contraseña del panel admin
  storeUrl: 'https://rsproparts.com/productos/',
};

// PREMIOS — editá nombre, probabilidad y color
// prob: porcentaje (todos deben sumar 100)
const PRIZES = [
  { id: 1, name: '3 CALCOMANÍAS',  desc: '3 planchas de calcomanías gratis en tu próxima compra', type: 'product',  prob: 53, color: '#16a34a', emoji: '🎨', coupon: true, code: 'CALCORULETA' },
  { id: 2, name: 'ENVÍO GRATIS',   desc: 'Envío gratis en tu próxima compra de +$50.000',         type: 'shipping', prob: 15, color: '#2563eb', emoji: '📦', coupon: true, code: 'ENVIORULETA'  },
  { id: 3, name: '5% OFF',         desc: '5% de descuento en tu próxima compra',                  type: 'discount', prob: 20, color: '#E8170D', emoji: '🔥', coupon: true, code: '5RULETA'      },
  { id: 4, name: '10% OFF',        desc: '10% de descuento en tu próxima compra',                 type: 'discount', prob: 12, color: '#cc1109', emoji: '🎯', coupon: true, code: '10RULETA'     },
];

/* ══════════════════════════════════════════════════════ */

let currentUser = null;
let isSpinning  = false;
let timerInterval = null;

// storage helpers
function getLog() {
  try { return JSON.parse(localStorage.getItem('rsp_log') || '[]'); } catch { return []; }
}
function saveLog(log) {
  try { localStorage.setItem('rsp_log', JSON.stringify(log)); } catch {}
}
function getUsedOrders() {
  try { return JSON.parse(localStorage.getItem('rsp_orders') || '[]'); } catch { return []; }
}
function addUsedOrder(ord) {
  const list = getUsedOrders();
  list.push(ord);
  try { localStorage.setItem('rsp_orders', JSON.stringify(list)); } catch {}
}
function getMinAmount() {
  return parseInt(localStorage.getItem('rsp_min') || CONFIG.minAmount);
}

// ── SCREENS ──
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
}

// ── VALIDATE & GO TO SPIN ──
function validateAndSpin() {
  const email  = document.getElementById('input-email').value.trim();
  const order  = document.getElementById('input-order').value.trim();
  const amount = parseFloat(document.getElementById('input-amount').value);
  const min    = getMinAmount();

  if (!email || !email.includes('@')) {
    alert('Ingresá un email válido.'); return;
  }
  if (!order) {
    alert('Ingresá tu número de orden.'); return;
  }
  if (!amount || amount < min) {
    alert(`El monto mínimo para participar es $${min.toLocaleString('es-AR')}.`); return;
  }
  const used = getUsedOrders();
  if (used.includes(order)) {
    alert('Este número de orden ya fue utilizado. Cada orden tiene un único giro.');
    return;
  }

  currentUser = { email, order, amount };
  document.getElementById('spin-name').textContent = email.split('@')[0];
  addUsedOrder(order);
  drawWheel(0);
  showScreen('spin');
}

// ── WHEEL DRAWING ──
const CANVAS_SIZE = 420;

function drawWheel(rotationRad) {
  const canvas = document.getElementById('wheel');
  const ctx    = canvas.getContext('2d');
  const cx = CANVAS_SIZE / 2, cy = CANVAS_SIZE / 2, r = CANVAS_SIZE / 2 - 4;

  ctx.clearRect(0, 0, CANVAS_SIZE, CANVAS_SIZE);

  const total = PRIZES.reduce((s, p) => s + p.prob, 0);
  let startAngle = rotationRad - Math.PI / 2;

  PRIZES.forEach((prize, i) => {
    const slice = (prize.prob / total) * 2 * Math.PI;
    const end   = startAngle + slice;
    const mid   = startAngle + slice / 2;

    // slice
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, startAngle, end);
    ctx.closePath();
    ctx.fillStyle   = prize.color;
    ctx.fill();
    ctx.strokeStyle = 'rgba(0,0,0,0.4)';
    ctx.lineWidth   = 1.5;
    ctx.stroke();

    // text
    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(mid);
    ctx.textAlign = 'right';
    ctx.fillStyle = prize.color === '#1a1a1a' || prize.color === '#141414'
                    ? 'rgba(255,255,255,0.25)' : '#fff';
    ctx.font      = `bold ${slice > 0.5 ? 13 : 10}px "Barlow Condensed", sans-serif`;
    ctx.letterSpacing = '0.06em';

    // truncate long names
    const txt = prize.name.length > 14 ? prize.name.slice(0, 13) + '…' : prize.name;
    ctx.fillText(txt, r - 14, 4);
    ctx.restore();

    startAngle = end;
  });

  // center circle
  ctx.beginPath();
  ctx.arc(cx, cy, 28, 0, 2 * Math.PI);
  ctx.fillStyle   = '#080808';
  ctx.fill();
  ctx.strokeStyle = '#2a2a2a';
  ctx.lineWidth   = 3;
  ctx.stroke();
}

// ── SPIN ──
function spinWheel() {
  if (isSpinning) return;
  isSpinning = true;
  document.getElementById('btn-spin').disabled = true;

  // pick result weighted
  const prize  = pickPrize();
  const prizeIndex = PRIZES.indexOf(prize);
  const total  = PRIZES.reduce((s,p)=>s+p.prob, 0);

  // calc target angle so pointer (top, 270°) lands on center of prize slice
  let cumAngle = 0;
  for (let i = 0; i < prizeIndex; i++) cumAngle += (PRIZES[i].prob / total) * 360;
  const sliceDeg  = (prize.prob / total) * 360;
  const sliceMid  = cumAngle + sliceDeg / 2;
  // pointer at top = 270° offset. We want sliceMid to be at 270°.
  const targetDeg = (270 - sliceMid + 360 * 6) % 360 + 360 * (5 + Math.floor(Math.random() * 3));
  const targetRad = targetDeg * Math.PI / 180;

  const duration = 5000 + Math.random() * 1500;
  const start    = performance.now();
  const startRad = 0;

  function easeOut(t) {
    return 1 - Math.pow(1 - t, 4);
  }

  function frame(now) {
    const elapsed = now - start;
    const t       = Math.min(elapsed / duration, 1);
    const current = startRad + easeOut(t) * targetRad;
    drawWheel(current);

    if (t < 1) {
      requestAnimationFrame(frame);
    } else {
      isSpinning = false;
      showResult(prize);
    }
  }
  requestAnimationFrame(frame);
}

function pickPrize() {
  const total = PRIZES.reduce((s,p)=>s+p.prob, 0);
  let r = Math.random() * total;
  for (const p of PRIZES) {
    r -= p.prob;
    if (r <= 0) return p;
  }
  return PRIZES[PRIZES.length - 1];
}

// ── SHOW RESULT ──
function showResult(prize) {
  const isWin = prize.type !== 'nothing';

  // save to log
  const log = getLog();
  log.unshift({
    email:  currentUser.email,
    order:  currentUser.order,
    amount: currentUser.amount,
    prize:  prize.name,
    type:   prize.type,
    win:    isWin,
    time:   new Date().toLocaleString('es-AR'),
  });
  saveLog(log);

  // badge
  const badge = document.getElementById('result-badge');
  badge.className = 'result-badge ' + (isWin ? 'win' : 'lose');
  badge.textContent = isWin ? '🏆 ¡GANASTE!' : 'Esta vez no fue';

  document.getElementById('result-emoji').textContent = prize.emoji;

  const title = document.getElementById('result-title');
  title.className = 'result-title ' + (isWin ? 'win' : 'lose');
  title.textContent = isWin ? '¡GANASTE!' : '¡SUERTE LA\nPRÓXIMA!';

  document.getElementById('result-prize-name').textContent = isWin ? prize.name : '';

  document.getElementById('result-desc').textContent = prize.desc;

  // coupon
  const couponBox = document.getElementById('coupon-box');
  if (isWin && prize.coupon && prize.code) {
    document.getElementById('coupon-code').textContent = prize.code;
    couponBox.classList.add('show');
  } else {
    couponBox.classList.remove('show');
  }

  // urgency timer
  const urgency = document.getElementById('urgency');
  if (isWin) {
    urgency.classList.add('show');
    startCountdown(15 * 60);
  } else {
    urgency.classList.remove('show');
  }

  // CTA
  document.getElementById('btn-cta').href = CONFIG.storeUrl;
  document.getElementById('btn-cta').textContent = isWin
    ? '🛒  USAR MI PREMIO'
    : '🛒  SEGUIR COMPRANDO';

  showScreen('result');

  // confetti if win
  if (isWin) setTimeout(() => launchConfetti(), 200);
}

function copyCoupon() {
  const code = document.getElementById('coupon-code').textContent;
  navigator.clipboard.writeText(code).then(() => {
    const btn = document.querySelector('.coupon-copy');
    btn.textContent = '✅ ¡Copiado!';
    setTimeout(() => btn.textContent = '📋 Copiar código', 2000);
  });
}

function startCountdown(seconds) {
  if (timerInterval) clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    if (seconds <= 0) { clearInterval(timerInterval); return; }
    seconds--;
    const m = Math.floor(seconds / 60).toString().padStart(2,'0');
    const s = (seconds % 60).toString().padStart(2,'0');
    const el = document.getElementById('countdown');
    if (el) el.textContent = m + ':' + s;
  }, 1000);
}

function goHome() {
  document.getElementById('input-email').value = '';
  document.getElementById('input-order').value = '';
  document.getElementById('input-amount').value = '';
  showScreen('intro');
}

// ── CONFETTI ──
function launchConfetti() {
  const canvas = document.getElementById('confetti-canvas');
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
  const ctx = canvas.getContext('2d');
  const particles = Array.from({length: 120}, () => ({
    x: Math.random() * canvas.width,
    y: -10,
    vx: (Math.random() - 0.5) * 4,
    vy: Math.random() * 4 + 2,
    w: Math.random() * 10 + 4,
    h: Math.random() * 6 + 2,
    angle: Math.random() * 360,
    va: (Math.random() - 0.5) * 8,
    color: ['#E8170D','#F5C842','#fff','#ff6b6b','#ffd700'][Math.floor(Math.random()*5)],
    life: 1,
  }));

  let frame = 0;
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    particles.forEach(p => {
      p.x += p.vx; p.y += p.vy;
      p.vy += 0.05; p.angle += p.va;
      p.life -= 0.006;
      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.angle * Math.PI/180);
      ctx.globalAlpha = Math.max(0, p.life);
      ctx.fillStyle = p.color;
      ctx.fillRect(-p.w/2, -p.h/2, p.w, p.h);
      ctx.restore();
    });
    frame++;
    if (frame < 200) requestAnimationFrame(draw);
    else ctx.clearRect(0, 0, canvas.width, canvas.height);
  }
  requestAnimationFrame(draw);
}

// ── ADMIN ──
function promptAdmin() {
  const pass = prompt('Contraseña de administrador:');
  if (pass === CONFIG.adminPass) {
    loadAdmin();
    showScreen('admin');
  } else if (pass !== null) {
    alert('Contraseña incorrecta.');
  }
}

function loadAdmin() {
  const log   = getLog();
  const wins  = log.filter(l=>l.win).length;
  const total = log.length;
  const pct   = total ? Math.round((wins/total)*100) : 0;

  document.getElementById('stat-total').textContent   = total;
  document.getElementById('stat-wins').textContent    = wins;
  document.getElementById('stat-losses').textContent  = total - wins;
  document.getElementById('stat-pct').textContent     = pct + '%';
  document.getElementById('admin-min').value          = getMinAmount();

  // prizes table
  const tbody = document.getElementById('prizes-tbody');
  tbody.innerHTML = PRIZES.map(p => {
    const pctColor = p.type==='discount'?'':'';
    const barClass = p.type==='product'?'green':p.type==='shipping'?'':p.type==='nothing'?'gray':'';
    return `<tr>
      <td style="color:var(--white);font-weight:600">${p.emoji} ${p.name}</td>
      <td><span class="tag-pill ${p.type}">${p.type}</span></td>
      <td>
        <div class="prob-bar">
          <span style="color:rgba(255,255,255,0.5);width:32px;font-size:13px">${p.prob}%</span>
          <div class="prob-track"><div class="prob-fill ${barClass}" style="width:${p.prob}%"></div></div>
        </div>
      </td>
      <td><span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:${p.color};border:1px solid rgba(255,255,255,0.1)"></span></td>
      <td style="color:var(--green)">✓</td>
    </tr>`;
  }).join('');

  // log
  const logEl = document.getElementById('spin-log');
  if (!log.length) {
    logEl.innerHTML = '<p style="color:rgba(255,255,255,0.2);font-size:13px;padding:16px 0">Todavía no hay giros registrados.</p>';
  } else {
    logEl.innerHTML = log.slice(0,50).map(l => `
      <div class="log-entry">
        <div class="log-dot ${l.win?'win':'lose'}"></div>
        <div class="log-email">${l.email}</div>
        <div class="log-prize">${l.prize}</div>
        <div class="log-time">${l.time}</div>
      </div>`).join('');
  }
}

function saveConfig() {
  const min = parseInt(document.getElementById('admin-min').value);
  if (min > 0) {
    localStorage.setItem('rsp_min', min);
    document.getElementById('min-display').textContent = min.toLocaleString('es-AR');
    alert('✅ Configuración guardada. Monto mínimo: $' + min.toLocaleString('es-AR'));
  }
}

function clearLog() {
  if (confirm('¿Seguro que querés borrar todo el historial de giros?')) {
    localStorage.removeItem('rsp_log');
    loadAdmin();
  }
}

// ── INIT ──
document.getElementById('min-display').textContent = getMinAmount().toLocaleString('es-AR');
drawWheel(0);
</script>
