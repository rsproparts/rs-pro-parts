
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RSProParts — Girá y Ganá</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --red:    #E8170D;
  --red2:   #ff2a1f;
  --dark:   #080808;
  --card:   #0f0f0f;
  --border: rgba(255,255,255,0.07);
  --white:  #F2F0EC;
  --gold:   #F5C842;
  --green:  #22c55e;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--dark);
  color: var(--white);
  font-family: 'Barlow Condensed', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── noise texture overlay ── */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  pointer-events: none; z-index: 0;
}

/* ── HEADER ── */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 32px;
  border-bottom: 1px solid var(--border);
  position: relative; z-index: 10;
}
.header-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px;
  letter-spacing: 0.08em;
  color: var(--white);
  display: flex; align-items: center; gap: 10px;
}
.header-logo .dot { color: var(--red); }
.header-badge {
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: var(--red);
  border: 1px solid rgba(232,23,13,0.3);
  padding: 5px 12px; border-radius: 2px;
}

/* ── SCREENS ── */
.screen { display: none; position: relative; z-index: 5; }
.screen.active { display: block; }

/* ── SCREEN 1: INTRO ── */
#screen-intro {
  min-height: calc(100vh - 61px);
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 24px;
  text-align: center;
}
#screen-intro.active { display: flex; }

.intro-eyebrow {
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.24em; text-transform: uppercase;
  color: var(--red); margin-bottom: 16px;
  display: flex; align-items: center; gap: 10px;
}
.intro-eyebrow::before, .intro-eyebrow::after {
  content: ''; flex: 1; height: 1px; background: rgba(232,23,13,0.3);
  max-width: 60px;
}

.intro-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(56px, 12vw, 96px);
  line-height: 0.85;
  letter-spacing: 0.01em;
  margin-bottom: 8px;
}
.intro-title .line2 { color: var(--red); }

.intro-sub {
  font-size: 15px; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  margin-bottom: 40px;
}

/* min amount card */
.min-card {
  display: inline-flex;
  align-items: center; gap: 14px;
  background: rgba(232,23,13,0.06);
  border: 1px solid rgba(232,23,13,0.2);
  border-radius: 4px;
  padding: 16px 28px;
  margin-bottom: 40px;
}
.min-card .icon { font-size: 22px; }
.min-card .text { text-align: left; }
.min-card .text strong {
  display: block;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px; letter-spacing: 0.05em;
  color: var(--red);
}
.min-card .text span {
  font-size: 11px; color: rgba(255,255,255,0.4);
  letter-spacing: 0.08em; text-transform: uppercase;
}

/* email input */
.form-group {
  width: 100%; max-width: 420px; margin-bottom: 16px;
}
.form-label {
  display: block; font-size: 10px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(255,255,255,0.4); margin-bottom: 8px;
  text-align: left;
}
.form-input {
  width: 100%;
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 14px 18px;
  color: var(--white);
  font-family: 'Barlow', sans-serif;
  font-size: 15px;
  outline: none;
  transition: border-color 0.2s;
}
.form-input:focus { border-color: rgba(232,23,13,0.5); }
.form-input::placeholder { color: rgba(255,255,255,0.2); }

.form-row {
  display: flex; gap: 10px; width: 100%; max-width: 420px; margin-bottom: 24px;
}
.form-row .form-group { margin-bottom: 0; flex: 1; }

.btn-main {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--red);
  color: #fff;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px; letter-spacing: 0.1em;
  padding: 16px 40px; border-radius: 3px;
  border: none; cursor: pointer;
  transition: background 0.2s, transform 0.1s;
  width: 100%; max-width: 420px;
  justify-content: center;
}
.btn-main:hover { background: var(--red2); }
.btn-main:active { transform: scale(0.98); }

.form-note {
  font-size: 11px; color: rgba(255,255,255,0.2);
  margin-top: 12px; max-width: 380px;
  line-height: 1.6;
}

/* ── SCREEN 2: SPIN ── */
#screen-spin {
  min-height: calc(100vh - 61px);
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32px 24px 48px;
  text-align: center;
  gap: 0;
}
#screen-spin.active { display: flex; }

.spin-greeting {
  font-size: 13px; font-weight: 700;
  letter-spacing: 0.16em; text-transform: uppercase;
  color: rgba(255,255,255,0.3); margin-bottom: 6px;
}
.spin-greeting span { color: var(--white); }

.spin-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(40px, 8vw, 64px);
  line-height: 0.9; margin-bottom: 32px;
}
.spin-title .red { color: var(--red); }

/* WHEEL CONTAINER */
.wheel-wrap {
  position: relative;
  width: min(420px, 90vw);
  height: min(420px, 90vw);
  margin: 0 auto 28px;
}

/* glow behind wheel */
.wheel-wrap::before {
  content: '';
  position: absolute;
  inset: -20px;
  background: radial-gradient(circle, rgba(232,23,13,0.12) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

/* outer ring */
.wheel-ring {
  position: absolute; inset: -8px;
  border-radius: 50%;
  background: conic-gradient(
    #1a1a1a 0deg, #2a2a2a 30deg,
    #1a1a1a 30deg, #2a2a2a 60deg,
    #1a1a1a 60deg, #2a2a2a 90deg,
    #1a1a1a 90deg, #2a2a2a 120deg,
    #1a1a1a 120deg, #2a2a2a 150deg,
    #1a1a1a 150deg, #2a2a2a 180deg,
    #1a1a1a 180deg, #2a2a2a 210deg,
    #1a1a1a 210deg, #2a2a2a 240deg,
    #1a1a1a 240deg, #2a2a2a 270deg,
    #1a1a1a 270deg, #2a2a2a 300deg,
    #1a1a1a 300deg, #2a2a2a 330deg,
    #1a1a1a 330deg, #2a2a2a 360deg
  );
  border: 3px solid #2a2a2a;
}

canvas#wheel {
  position: relative; z-index: 2;
  border-radius: 50%;
  box-shadow: 0 0 40px rgba(0,0,0,0.8), 0 0 0 4px #1a1a1a;
  width: 100%; height: 100%;
}

/* pointer */
.wheel-pointer {
  position: absolute;
  top: -18px; left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  width: 0; height: 0;
  border-left: 14px solid transparent;
  border-right: 14px solid transparent;
  border-top: 28px solid var(--red);
  filter: drop-shadow(0 2px 8px rgba(232,23,13,0.6));
}
.wheel-pointer::after {
  content: '';
  position: absolute;
  top: -32px; left: -8px;
  width: 16px; height: 16px;
  background: var(--red);
  border-radius: 50%;
  box-shadow: 0 0 12px rgba(232,23,13,0.8);
}

/* center hub */
.wheel-hub {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 52px; height: 52px;
  border-radius: 50%;
  background: var(--dark);
  border: 4px solid #2a2a2a;
  z-index: 10;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 9px; letter-spacing: 0.1em;
  color: rgba(255,255,255,0.3);
}

.spin-counter {
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(255,255,255,0.25); margin-bottom: 20px;
}
.spin-counter span { color: var(--red); }

.btn-spin {
  display: inline-flex; align-items: center; gap: 12px;
  background: var(--red);
  color: #fff;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 26px; letter-spacing: 0.1em;
  padding: 18px 56px; border-radius: 3px;
  border: none; cursor: pointer;
  transition: all 0.2s;
  box-shadow: 0 4px 24px rgba(232,23,13,0.35);
  position: relative; overflow: hidden;
}
.btn-spin::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(to right, transparent 0%, rgba(255,255,255,0.08) 50%, transparent 100%);
  transform: translateX(-100%);
  transition: transform 0.6s ease;
}
.btn-spin:hover::before { transform: translateX(100%); }
.btn-spin:hover { box-shadow: 0 6px 32px rgba(232,23,13,0.5); transform: translateY(-1px); }
.btn-spin:active { transform: scale(0.97); }
.btn-spin:disabled {
  background: #333; color: rgba(255,255,255,0.2);
  cursor: not-allowed; box-shadow: none; transform: none;
}

/* ── SCREEN 3: RESULT ── */
#screen-result {
  min-height: calc(100vh - 61px);
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 24px;
  text-align: center;
}
#screen-result.active { display: flex; }

.result-badge {
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  margin-bottom: 20px;
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 16px; border-radius: 2px;
}
.result-badge.win {
  color: var(--gold);
  background: rgba(245,200,66,0.1);
  border: 1px solid rgba(245,200,66,0.3);
}
.result-badge.lose {
  color: rgba(255,255,255,0.3);
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
}

.result-emoji { font-size: 64px; margin-bottom: 16px; display: block; }

.result-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(48px, 10vw, 80px);
  line-height: 0.88; margin-bottom: 12px;
}
.result-title.win { color: var(--gold); }
.result-title.lose { color: rgba(255,255,255,0.3); }

.result-prize-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(28px, 6vw, 48px);
  color: var(--white); margin-bottom: 8px;
}

.result-desc {
  font-size: 13px; color: rgba(255,255,255,0.4);
  line-height: 1.6; max-width: 360px; margin-bottom: 32px;
}

/* coupon box */
.coupon-box {
  background: rgba(245,200,66,0.05);
  border: 2px dashed rgba(245,200,66,0.3);
  border-radius: 6px;
  padding: 20px 32px;
  margin-bottom: 32px;
  display: none;
}
.coupon-box.show { display: block; }
.coupon-label {
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: rgba(245,200,66,0.6); margin-bottom: 8px;
}
.coupon-code {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 38px; letter-spacing: 0.12em;
  color: var(--gold);
}
.coupon-copy {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(245,200,66,0.5); cursor: pointer;
  margin-top: 8px; border: none; background: none;
  transition: color 0.2s;
}
.coupon-copy:hover { color: var(--gold); }

/* timer urgency */
.urgency {
  font-size: 11px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--red); margin-bottom: 24px;
  display: none;
}
.urgency.show { display: block; }
.urgency .timer { color: var(--white); }

.btn-cta {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--red);
  color: #fff;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px; letter-spacing: 0.1em;
  padding: 16px 40px; border-radius: 3px;
  border: none; cursor: pointer; text-decoration: none;
  transition: all 0.2s; margin-bottom: 16px;
}
.btn-cta:hover { background: var(--red2); transform: translateY(-1px); }

.btn-secondary {
  display: inline-flex; align-items: center; gap: 8px;
  background: transparent;
  color: rgba(255,255,255,0.3);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 13px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  padding: 10px 24px; border-radius: 3px;
  border: 1px solid var(--border); cursor: pointer;
  transition: all 0.2s; text-decoration: none;
}
.btn-secondary:hover { border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.6); }

/* confetti canvas */
#confetti-canvas {
  position: fixed; inset: 0;
  pointer-events: none; z-index: 100;
}

/* ── ADMIN PANEL ── */
#screen-admin {
  min-height: calc(100vh - 61px);
  display: none;
  padding: 40px 32px;
}
#screen-admin.active { display: block; }

.admin-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 36px;
}
.admin-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 40px; letter-spacing: 0.04em;
}
.admin-title span { color: var(--red); }

.admin-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px; margin-bottom: 40px;
}

.stat-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 4px; padding: 24px;
}
.stat-card .stat-label {
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(255,255,255,0.3); margin-bottom: 8px;
}
.stat-card .stat-value {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 44px; letter-spacing: 0.02em;
  color: var(--white); line-height: 1;
}
.stat-card .stat-value.red { color: var(--red); }
.stat-card .stat-value.gold { color: var(--gold); }

.section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 28px; letter-spacing: 0.05em;
  margin-bottom: 16px; margin-top: 32px;
  display: flex; align-items: center; gap: 12px;
}
.section-title::after {
  content: ''; flex: 1; height: 1px;
  background: var(--border);
}

/* prizes table */
.table-wrap { overflow-x: auto; }
table {
  width: 100%; border-collapse: collapse;
  font-size: 13px;
}
th {
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.18em; text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  padding: 10px 16px; text-align: left;
  border-bottom: 1px solid var(--border);
}
td {
  padding: 14px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.03);
  color: rgba(255,255,255,0.7);
  vertical-align: middle;
}
tr:hover td { background: rgba(255,255,255,0.02); }

.prob-bar {
  display: flex; align-items: center; gap: 8px;
}
.prob-track {
  flex: 1; height: 4px;
  background: rgba(255,255,255,0.06);
  border-radius: 2px; overflow: hidden;
}
.prob-fill {
  height: 100%; border-radius: 2px;
  background: var(--red);
}
.prob-fill.gold { background: var(--gold); }
.prob-fill.green { background: var(--green); }
.prob-fill.gray { background: rgba(255,255,255,0.15); }

.tag-pill {
  display: inline-block;
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  padding: 3px 8px; border-radius: 2px;
}
.tag-pill.discount { background: rgba(232,23,13,0.12); color: var(--red); }
.tag-pill.product  { background: rgba(34,197,94,0.1);  color: var(--green); }
.tag-pill.shipping { background: rgba(59,130,246,0.1); color: #60a5fa; }
.tag-pill.nothing  { background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.3); }

/* spin log */
.log-entry {
  display: flex; align-items: center; gap: 14px;
  padding: 12px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.03);
  font-size: 12px;
}
.log-dot {
  width: 8px; height: 8px; border-radius: 50%;
  flex-shrink: 0;
}
.log-dot.win  { background: var(--gold); box-shadow: 0 0 6px rgba(245,200,66,0.5); }
.log-dot.lose { background: rgba(255,255,255,0.2); }
.log-email { flex: 1; color: var(--white); font-weight: 600; }
.log-prize { flex: 2; color: rgba(255,255,255,0.5); }
.log-time  { color: rgba(255,255,255,0.25); white-space: nowrap; }

/* input/btn admin */
.admin-form { display: flex; gap: 10px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 20px; }
.admin-input {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: 3px; padding: 11px 14px;
  color: var(--white); font-family: 'Barlow', sans-serif;
  font-size: 14px; outline: none; min-width: 200px;
  transition: border-color 0.2s;
}
.admin-input:focus { border-color: rgba(232,23,13,0.4); }
.btn-admin {
  background: var(--red); color: #fff;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 16px; letter-spacing: 0.1em;
  padding: 11px 22px; border-radius: 3px;
  border: none; cursor: pointer; transition: background 0.2s;
}
.btn-admin:hover { background: var(--red2); }

/* toggle admin link */
#admin-toggle {
  position: fixed; bottom: 20px; right: 20px;
  font-size: 9px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(255,255,255,0.1); cursor: pointer;
  z-index: 999; border: none; background: none;
  transition: color 0.2s;
}
#admin-toggle:hover { color: rgba(255,255,255,0.3); }

/* ── animations ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.5; }
}
@keyframes winPop {
  0%   { transform: scale(0.5); opacity: 0; }
  70%  { transform: scale(1.1); }
  100% { transform: scale(1);   opacity: 1; }
}
.animate-in { animation: fadeUp 0.5s ease both; }
.win-pop    { animation: winPop 0.6s cubic-bezier(0.175,0.885,0.32,1.275) both; }

@media (max-width: 600px) {
  .header { padding: 14px 18px; }
  .admin-grid { grid-template-columns: 1fr 1fr; }
  th, td { padding: 10px 10px; }
}
</style>
</head>
<body>

<canvas id="confetti-canvas"></canvas>

<!-- ── HEADER ── -->
<header class="header">
  <div class="header-logo">
    RS<span class="dot">●</span>PRO PARTS
  </div>
  <div class="header-badge">🎰 Girá y Ganá</div>
</header>

<!-- ════════════════════════════════ SCREEN 1: INTRO ════════════════════════════════ -->
<div id="screen-intro" class="screen active">
  <div class="intro-eyebrow">Exclusivo para clientes</div>
  <h1 class="intro-title animate-in">
    GIRÁ<br><span class="line2">Y GANÁ.</span>
  </h1>
  <p class="intro-sub animate-in" style="animation-delay:.1s">Una sola oportunidad por compra</p>

  <div class="min-card animate-in" style="animation-delay:.2s">
    <span class="icon">🛒</span>
    <div class="text">
      <strong>$<span id="min-display">50.000</span> mínimo</strong>
      <span>Monto mínimo de compra para participar</span>
    </div>
  </div>

  <div class="form-group animate-in" style="animation-delay:.3s">
    <label class="form-label">Tu email de compra</label>
    <input class="form-input" type="email" id="input-email" placeholder="correo@ejemplo.com">
  </div>
  <div class="form-row animate-in" style="animation-delay:.35s">
    <div class="form-group">
      <label class="form-label">N° de orden</label>
      <input class="form-input" type="text" id="input-order" placeholder="Ej: 1234">
    </div>
    <div class="form-group">
      <label class="form-label">Monto de compra ($)</label>
      <input class="form-input" type="number" id="input-amount" placeholder="Ej: 80000">
    </div>
  </div>

  <button class="btn-main animate-in" style="animation-delay:.4s" onclick="validateAndSpin()">
    ¡QUIERO GIRAR! 🎰
